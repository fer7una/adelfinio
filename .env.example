# Core
PROJECT_NAME=adelfinio
TZ=Europe/Madrid

# n8n
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=REPLACE_WITH_LONG_RANDOM_STRING
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
N8N_LOG_LEVEL=info
N8N_RUNNERS_ENABLED=true
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
N8N_SECURE_COOKIE=false
EXECUTIONS_MODE=regular
N8N_METRICS=true

# n8n -> PostgreSQL
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# n8n -> Redis (ready for queues/locks)
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_DB=0

# PostgreSQL service
POSTGRES_PORT=5432
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Redis service
REDIS_PORT=6379

# MinIO
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
MINIO_DEFAULT_BUCKET=tiktok-assets

# TikTok API placeholders (TODO: real values in .env)
TIKTOK_CLIENT_KEY=TODO_TIKTOK_CLIENT_KEY
TIKTOK_CLIENT_SECRET=TODO_TIKTOK_CLIENT_SECRET
TIKTOK_REDIRECT_URI=TODO_TIKTOK_REDIRECT_URI
TIKTOK_REFRESH_TOKEN=TODO_TIKTOK_REFRESH_TOKEN

# OpenAI (image + voice generation)
OPENAI_API_KEY=TODO_OPENAI_API_KEY
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_STORY_MODEL=gpt-5.4
OPENAI_CHARACTER_MODEL=gpt-5.4
OPENAI_STORY_CATALOG_MODEL=gpt-5.4
OPENAI_EPISODE_MODEL=gpt-5.4
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=auto
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
