{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "render_plan_common.schema.json",
  "title": "Render Plan Common",
  "$defs": {
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    },
    "bboxNorm": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "pointNorm": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    }
  }
}
