{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene_audio_plan.schema.json",
  "title": "Scene Audio Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "scene_index",
    "scene_duration_final_s",
    "utterances",
    "event_bindings"
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "scene_index": {
      "type": "integer",
      "minimum": 1
    },
    "scene_duration_final_s": {
      "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
    },
    "utterances": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "utterance_id",
          "audio_clip_path",
          "audio_duration_s",
          "scene_audio_start_s",
          "scene_audio_end_s"
        ],
        "properties": {
          "utterance_id": {
            "type": "string",
            "minLength": 1
          },
          "audio_clip_path": {
            "type": "string",
            "minLength": 1
          },
          "audio_duration_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "scene_audio_start_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "scene_audio_end_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          }
        }
      }
    },
    "event_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "utterance_id",
          "speech_start_s",
          "speech_end_s",
          "visible_start_s",
          "visible_end_s",
          "audio_start_s",
          "audio_end_s",
          "pre_roll_clean_s",
          "legibility_floor_s"
        ],
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "utterance_id": {
            "type": "string",
            "minLength": 1
          },
          "speech_start_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "speech_end_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "visible_start_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "visible_end_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "audio_start_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "audio_end_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "pre_roll_clean_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "legibility_floor_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          }
        }
      }
    }
  }
}
