{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adelfinio.local/schemas/character.schema.json",
  "title": "Character",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "character_id",
    "display_name",
    "historical_period",
    "role",
    "biography_short",
    "voice_profile",
    "visual_profile",
    "state",
    "continuity",
    "emotional_state",
    "arc_state"
  ],
  "properties": {
    "character_id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]{3,64}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      },
      "uniqueItems": true,
      "default": []
    },
    "historical_period": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "role": {
      "type": "string",
      "enum": [
        "monarch",
        "military",
        "political",
        "religious",
        "civilian",
        "chronicler",
        "other"
      ]
    },
    "biography_short": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1200
    },
    "voice_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tts_voice",
        "tone",
        "words_per_second",
        "delivery_modifiers"
      ],
      "properties": {
        "tts_voice": {
          "type": "string",
          "enum": [
            "alloy",
            "echo",
            "fable",
            "onyx",
            "nova",
            "shimmer",
            "coral",
            "verse",
            "ballad",
            "ash",
            "sage",
            "marin",
            "cedar"
          ]
        },
        "tone": {
          "type": "string",
          "minLength": 3,
          "maxLength": 80
        },
        "words_per_second": {
          "type": "number",
          "minimum": 1.2,
          "maximum": 4.5
        },
        "delivery_modifiers": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "normal",
            "shout"
          ],
          "properties": {
            "normal": {
              "type": "number",
              "minimum": 0.7,
              "maximum": 1.4
            },
            "shout": {
              "type": "number",
              "minimum": 0.7,
              "maximum": 1.8
            }
          }
        }
      }
    },
    "visual_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "age_range",
        "hair",
        "beard",
        "clothing",
        "palette",
        "style_notes"
      ],
      "properties": {
        "age_range": {
          "type": "string",
          "minLength": 3,
          "maxLength": 40
        },
        "hair": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "beard": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "clothing": {
          "type": "string",
          "minLength": 3,
          "maxLength": 200
        },
        "palette": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          }
        },
        "style_notes": {
          "type": "string",
          "minLength": 5,
          "maxLength": 400
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "location",
        "alliances",
        "conflicts",
        "last_seen_episode_id",
        "last_updated"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive",
            "deceased",
            "unknown"
          ]
        },
        "location": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "alliances": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]{3,64}$"
          },
          "default": []
        },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]{3,64}$"
          },
          "default": []
        },
        "last_seen_episode_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(main|teaser)-[0-9]{8}-[a-z0-9_\\-]+$"
        },
        "last_updated": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "continuity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "must_keep",
        "must_avoid"
      ],
      "properties": {
        "must_keep": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 200
          }
        },
        "must_avoid": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 200
          },
          "default": []
        }
      }
    },
    "emotional_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dominant_emotion",
        "intensity",
        "valence",
        "arousal",
        "trigger_summary"
      ],
      "properties": {
        "dominant_emotion": {
          "type": "string",
          "enum": [
            "calm",
            "hope",
            "fear",
            "anger",
            "sadness",
            "resolve",
            "joy",
            "grief",
            "pride",
            "shame",
            "uncertainty"
          ]
        },
        "intensity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "valence": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "arousal": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "trigger_summary": {
          "type": "string",
          "minLength": 5,
          "maxLength": 300
        }
      }
    },
    "arc_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage",
        "external_goal",
        "internal_need",
        "contradiction",
        "change_vector",
        "last_event_id"
      ],
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "setup",
            "ascent",
            "crisis",
            "turn",
            "resolution",
            "legacy"
          ]
        },
        "external_goal": {
          "type": "string",
          "minLength": 8,
          "maxLength": 240
        },
        "internal_need": {
          "type": "string",
          "minLength": 8,
          "maxLength": 240
        },
        "contradiction": {
          "type": "string",
          "minLength": 8,
          "maxLength": 240
        },
        "change_vector": {
          "type": "string",
          "minLength": 8,
          "maxLength": 240
        },
        "last_event_id": {
          "type": "string",
          "pattern": "^evt-[0-9]{4,8}$"
        }
      }
    }
  }
}
