{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adelfinio.local/schemas/daily_plan.schema.json",
  "title": "DailyPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "date",
    "targets",
    "main_episodes",
    "teaser_episodes",
    "notes"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "pattern": "^plan-[0-9]{8}$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "main_count",
        "teaser_count"
      ],
      "properties": {
        "main_count": {
          "type": "integer",
          "const": 2
        },
        "teaser_count": {
          "type": "integer",
          "const": 2
        }
      }
    },
    "main_episodes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "episode_id",
          "source_event_ids",
          "priority"
        ],
        "properties": {
          "episode_id": {
            "type": "string",
            "pattern": "^main-[0-9]{8}-[a-z0-9_\\-]+$"
          },
          "source_event_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^evt-[0-9]{4,8}$"
            }
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          }
        }
      }
    },
    "teaser_episodes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "episode_id",
          "parent_episode_id",
          "strategy"
        ],
        "properties": {
          "episode_id": {
            "type": "string",
            "pattern": "^teaser-[0-9]{8}-[a-z0-9_\\-]+$"
          },
          "parent_episode_id": {
            "type": "string",
            "pattern": "^main-[0-9]{8}-[a-z0-9_\\-]+$"
          },
          "strategy": {
            "type": "string",
            "enum": [
              "cliffhanger",
              "quote",
              "question"
            ]
          }
        }
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 1200
    }
  }
}
