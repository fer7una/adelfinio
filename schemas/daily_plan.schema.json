{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adelfinio.local/schemas/daily_plan.schema.json",
  "title": "DailyPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "date",
    "targets",
    "main_episodes",
    "teaser_episodes",
    "notes"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "pattern": "^plan-[0-9]{8}$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "main_count",
        "teaser_count"
      ],
      "properties": {
        "main_count": {
          "type": "integer",
          "const": 2
        },
        "teaser_count": {
          "type": "integer",
          "const": 2
        }
      }
    },
    "main_episodes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "episode_id",
          "source_event_ids",
          "priority",
          "target_duration_seconds",
          "storytelling"
        ],
        "properties": {
          "episode_id": {
            "type": "string",
            "pattern": "^main-[0-9]{8}-[a-z0-9_\\-]+$"
          },
          "source_event_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^evt-[0-9]{4,8}$"
            }
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          },
          "target_duration_seconds": {
            "type": "integer",
            "minimum": 45,
            "maximum": 180
          },
          "storytelling": {
            "$ref": "#/$defs/storytellingPlan"
          }
        }
      }
    },
    "teaser_episodes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "episode_id",
          "parent_episode_id",
          "strategy",
          "target_duration_seconds",
          "storytelling"
        ],
        "properties": {
          "episode_id": {
            "type": "string",
            "pattern": "^teaser-[0-9]{8}-[a-z0-9_\\-]+$"
          },
          "parent_episode_id": {
            "type": "string",
            "pattern": "^main-[0-9]{8}-[a-z0-9_\\-]+$"
          },
          "strategy": {
            "type": "string",
            "enum": [
              "cliffhanger",
              "quote",
              "question"
            ]
          },
          "target_duration_seconds": {
            "type": "integer",
            "minimum": 10,
            "maximum": 45
          },
          "storytelling": {
            "$ref": "#/$defs/storytellingPlan"
          }
        }
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 1200
    }
  },
  "$defs": {
    "dialogueLine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "speaker",
        "line",
        "delivery"
      ],
      "properties": {
        "speaker": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "line": {
          "type": "string",
          "minLength": 2,
          "maxLength": 180
        },
        "delivery": {
          "type": "string",
          "enum": [
            "normal",
            "shout"
          ]
        }
      }
    },
    "sceneTiming": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "narration_seconds",
        "dialogue_seconds",
        "visual_hold_seconds",
        "target_duration_seconds",
        "narration_words",
        "dialogue_words",
        "total_words"
      ],
      "properties": {
        "narration_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "dialogue_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "visual_hold_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "target_duration_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "narration_words": {
          "type": "integer",
          "minimum": 0
        },
        "dialogue_words": {
          "type": "integer",
          "minimum": 0
        },
        "total_words": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "storytellingScene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scene_index",
        "story_role",
        "source_beat",
        "visual_focus",
        "transition_note",
        "timing",
        "narration",
        "dialogue",
        "target_duration_seconds"
      ],
      "properties": {
        "scene_index": {
          "type": "integer",
          "minimum": 1
        },
        "story_role": {
          "type": "string",
          "minLength": 3,
          "maxLength": 32
        },
        "source_beat": {
          "type": "string",
          "minLength": 8,
          "maxLength": 220
        },
        "visual_focus": {
          "type": "string",
          "minLength": 12,
          "maxLength": 280
        },
        "transition_note": {
          "type": "string",
          "minLength": 12,
          "maxLength": 220
        },
        "timing": {
          "$ref": "#/$defs/sceneTiming"
        },
        "narration": {
          "type": "string",
          "minLength": 12,
          "maxLength": 240
        },
        "dialogue": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "$ref": "#/$defs/dialogueLine"
          }
        },
        "target_duration_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        }
      }
    },
    "storytellingPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "narrative_mode",
        "premise",
        "dramatic_question",
        "ending_payoff",
        "scene_outline",
        "scene_count",
        "target_duration_seconds"
      ],
      "properties": {
        "narrative_mode": {
          "type": "string",
          "minLength": 3,
          "maxLength": 32
        },
        "premise": {
          "type": "string",
          "minLength": 20,
          "maxLength": 260
        },
        "dramatic_question": {
          "type": "string",
          "minLength": 20,
          "maxLength": 260
        },
        "ending_payoff": {
          "type": "string",
          "minLength": 12,
          "maxLength": 260
        },
        "scene_outline": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/storytellingScene"
          }
        },
        "scene_count": {
          "type": "integer",
          "minimum": 2,
          "maximum": 20
        },
        "target_duration_seconds": {
          "type": "integer",
          "minimum": 10,
          "maximum": 180
        }
      }
    }
  }
}
