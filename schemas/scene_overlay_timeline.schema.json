{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene_overlay_timeline.schema.json",
  "title": "Scene Overlay Timeline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "scene_index",
    "scene_duration_s",
    "canvas",
    "source_image_path",
    "source_clean_video_path",
    "events"
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "scene_index": {
      "type": "integer",
      "minimum": 1
    },
    "scene_duration_s": {
      "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "source_image_path": {
      "type": "string",
      "minLength": 1
    },
    "source_clean_video_path": {
      "type": "string",
      "minLength": 1
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "kind",
          "speaker",
          "delivery",
          "text",
          "start_s",
          "end_s",
          "fade_in_s",
          "fade_out_s",
          "crossfade_text_s",
          "pre_roll_clean_s",
          "region",
          "layout",
          "visibility_policy",
          "occlusion_analysis"
        ],
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "narration",
              "dialogue",
              "shout"
            ]
          },
          "speaker": {
            "type": "string"
          },
          "delivery": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "start_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "end_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "fade_in_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "fade_out_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "crossfade_text_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "pre_roll_clean_s": {
            "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
          },
          "region": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "box_norm",
              "tail_anchor_norm",
              "size_mode"
            ],
            "properties": {
              "box_norm": {
                "$ref": "render_plan_common.schema.json#/$defs/bboxNorm"
              },
              "tail_anchor_norm": {
                "type": "array",
                "items": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              },
              "size_mode": {
                "type": "string",
                "enum": [
                  "fixed",
                  "adaptive"
                ]
              }
            }
          },
          "layout": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "font_px",
              "line_count",
              "padding_x_px",
              "padding_y_px"
            ],
            "properties": {
              "font_px": {
                "type": "integer",
                "minimum": 1
              },
              "line_count": {
                "type": "integer",
                "minimum": 1
              },
              "padding_x_px": {
                "type": "integer",
                "minimum": 0
              },
              "padding_y_px": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "visibility_policy": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "single_visible_unit",
              "hide_others"
            ],
            "properties": {
              "single_visible_unit": {
                "type": "boolean"
              },
              "hide_others": {
                "type": "boolean"
              }
            }
          },
          "occlusion_analysis": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "covers_speaker",
              "covers_focus",
              "covers_listener_face",
              "requires_pre_roll_clean",
              "recommended_pre_roll_s"
            ],
            "properties": {
              "covers_speaker": {
                "type": "boolean"
              },
              "covers_focus": {
                "type": "boolean"
              },
              "covers_listener_face": {
                "type": "boolean"
              },
              "requires_pre_roll_clean": {
                "type": "boolean"
              },
              "recommended_pre_roll_s": {
                "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
              }
            }
          }
        }
      }
    }
  }
}
