{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adelfinio.local/schemas/episode.schema.json",
  "title": "Episode",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "episode_type",
    "status",
    "language",
    "timeline_event_ids",
    "title",
    "hook",
    "storytelling",
    "scenes",
    "characters",
    "duration_seconds",
    "human_review"
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "pattern": "^(main|teaser)-[0-9]{8}-[a-z0-9_\\-]+$"
    },
    "episode_type": {
      "type": "string",
      "enum": [
        "main",
        "teaser"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "generated",
        "pending_review",
        "approved_for_inbox",
        "sent_to_tiktok_inbox",
        "needs_changes"
      ]
    },
    "language": {
      "type": "string",
      "const": "es"
    },
    "narrative_tone": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]{3,64}$"
    },
    "timeline_event_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^evt-[0-9]{4,8}$"
      }
    },
    "parent_episode_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^main-[0-9]{8}-[a-z0-9_\\-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 8,
      "maxLength": 120
    },
    "hook": {
      "type": "string",
      "minLength": 20,
      "maxLength": 300
    },
    "storytelling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "narrative_mode",
        "premise",
        "dramatic_question",
        "ending_payoff"
      ],
      "properties": {
        "narrative_mode": {
          "type": "string",
          "minLength": 3,
          "maxLength": 32
        },
        "premise": {
          "type": "string",
          "minLength": 20,
          "maxLength": 260
        },
        "dramatic_question": {
          "type": "string",
          "minLength": 20,
          "maxLength": 260
        },
        "ending_payoff": {
          "type": "string",
          "minLength": 12,
          "maxLength": 260
        }
      }
    },
    "plot_twist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setup",
        "reveal",
        "payoff"
      ],
      "properties": {
        "setup": {
          "type": "string",
          "minLength": 20,
          "maxLength": 400
        },
        "reveal": {
          "type": "string",
          "minLength": 20,
          "maxLength": 400
        },
        "payoff": {
          "type": "string",
          "minLength": 20,
          "maxLength": 400
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scene_index",
          "story_role",
          "source_beat",
          "visual_focus",
          "transition_note",
          "timing",
          "narration",
          "visual_prompt",
          "estimated_seconds"
        ],
        "properties": {
          "scene_index": {
            "type": "integer",
            "minimum": 1
          },
          "story_role": {
            "type": "string",
            "minLength": 3,
            "maxLength": 32
          },
          "source_beat": {
            "type": "string",
            "minLength": 8,
            "maxLength": 220
          },
          "visual_focus": {
            "type": "string",
            "minLength": 12,
            "maxLength": 280
          },
          "transition_note": {
            "type": "string",
            "minLength": 12,
            "maxLength": 220
          },
          "timing": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "narration_seconds",
              "dialogue_seconds",
              "visual_hold_seconds",
              "target_duration_seconds",
              "narration_words",
              "dialogue_words",
              "total_words"
            ],
            "properties": {
              "narration_seconds": {
                "type": "integer",
                "minimum": 1
              },
              "dialogue_seconds": {
                "type": "integer",
                "minimum": 0
              },
              "visual_hold_seconds": {
                "type": "integer",
                "minimum": 0
              },
              "target_duration_seconds": {
                "type": "integer",
                "minimum": 1
              },
              "narration_words": {
                "type": "integer",
                "minimum": 0
              },
              "dialogue_words": {
                "type": "integer",
                "minimum": 0
              },
              "total_words": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "narration": {
            "type": "string",
            "minLength": 20,
            "maxLength": 900
          },
          "visual_prompt": {
            "type": "string",
            "minLength": 20,
            "maxLength": 900
          },
          "estimated_seconds": {
            "type": "integer",
            "minimum": 2,
            "maximum": 90
          },
          "dialogue": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "speaker",
                "line",
                "delivery"
              ],
              "properties": {
                "speaker": {
                  "type": "string",
                  "minLength": 2,
                  "maxLength": 80
                },
                "line": {
                  "type": "string",
                  "minLength": 8,
                  "maxLength": 180
                },
                "delivery": {
                  "type": "string",
                  "enum": [
                    "normal",
                    "shout"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_\\-]{3,64}$"
      }
    },
    "character_beats": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "character_id",
          "emotion_before",
          "emotion_after",
          "arc_stage_before",
          "arc_stage_after",
          "beat_summary"
        ],
        "properties": {
          "character_id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]{3,64}$"
          },
          "emotion_before": {
            "type": "string",
            "enum": [
              "calm",
              "hope",
              "fear",
              "anger",
              "sadness",
              "resolve",
              "joy",
              "grief",
              "pride",
              "shame",
              "uncertainty"
            ]
          },
          "emotion_after": {
            "type": "string",
            "enum": [
              "calm",
              "hope",
              "fear",
              "anger",
              "sadness",
              "resolve",
              "joy",
              "grief",
              "pride",
              "shame",
              "uncertainty"
            ]
          },
          "arc_stage_before": {
            "type": "string",
            "enum": [
              "setup",
              "ascent",
              "crisis",
              "turn",
              "resolution",
              "legacy"
            ]
          },
          "arc_stage_after": {
            "type": "string",
            "enum": [
              "setup",
              "ascent",
              "crisis",
              "turn",
              "resolution",
              "legacy"
            ]
          },
          "beat_summary": {
            "type": "string",
            "minLength": 12,
            "maxLength": 300
          }
        }
      }
    },
    "duration_seconds": {
      "type": "integer",
      "minimum": 15,
      "maximum": 180
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "status"
      ],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "changes_requested"
          ]
        },
        "reviewer": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 120
        },
        "notes": {
          "type": "string",
          "maxLength": 1500
        }
      }
    },
    "asset_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "audio": {
          "type": "string"
        },
        "video": {
          "type": "string"
        },
        "subtitles": {
          "type": "string"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "episode_type": {
            "const": "main"
          }
        }
      },
      "then": {
        "required": [
          "plot_twist",
          "character_beats"
        ],
        "properties": {
          "parent_episode_id": {
            "type": "null"
          },
          "duration_seconds": {
            "type": "integer",
            "minimum": 90,
            "maximum": 180
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "episode_type": {
            "const": "teaser"
          }
        }
      },
      "then": {
        "required": [
          "parent_episode_id"
        ],
        "properties": {
          "duration_seconds": {
            "type": "integer",
            "minimum": 15,
            "maximum": 30
          }
        }
      }
    }
  ]
}
