{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene_alignment.schema.json",
  "title": "Scene Alignment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "scene_index",
    "utterances"
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "scene_index": {
      "type": "integer",
      "minimum": 1
    },
    "utterances": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "utterance_id",
          "audio_clip_path",
          "alignment_method",
          "words"
        ],
        "properties": {
          "utterance_id": {
            "type": "string",
            "minLength": 1
          },
          "audio_clip_path": {
            "type": "string",
            "minLength": 1
          },
          "alignment_method": {
            "type": "string",
            "minLength": 1
          },
          "words": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "index",
                "text",
                "start_s",
                "end_s"
              ],
              "properties": {
                "index": {
                  "type": "integer",
                  "minimum": 0
                },
                "text": {
                  "type": "string",
                  "minLength": 1
                },
                "start_s": {
                  "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
                },
                "end_s": {
                  "$ref": "render_plan_common.schema.json#/$defs/nonNegativeNumber"
                }
              }
            }
          }
        }
      }
    }
  }
}
